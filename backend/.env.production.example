APP_ENV=production
SECRET_KEY=replace-with-production-secret
JWT_SECRET_KEY=replace-with-production-jwt-secret
DATABASE_URL=postgresql://dxcon:dxcon@postgres:5432/dxcon

LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
CORRELATION_ID_HEADER=X-Correlation-ID

BUILD_VERSION=2.5.0
GIT_SHA=local
BUILD_TIME=

WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=280
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_SECONDS=2
STARTUP_VALIDATE_DB=true

CORS_ORIGINS=https://app.dxcon.com,https://admin.dxcon.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TTL_SECONDS=60
SLOW_QUERY_THRESHOLD_MS=100
BACKGROUND_TASK_WORKERS=8

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dxcon-prod
SMTP_PASSWORD=replace-me
SMTP_FROM=noreply@dxcon.com
SMTP_USE_TLS=true

STORAGE_PATH=/var/lib/dxcon/uploads
STORAGE_BACKEND=local
