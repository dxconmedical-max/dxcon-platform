# DxCon staging deployment environment (copy to deployment/env/staging.env)
APP_ENV=staging
SECRET_KEY=replace-with-staging-secret-min-32-chars
JWT_SECRET_KEY=replace-with-staging-jwt-secret-min-32-chars
DATABASE_URL=postgresql://dxcon:dxcon@postgres:5432/dxcon_staging
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=https://staging.dxcon.test,https://admin-staging.dxcon.test
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dxcon-staging
SMTP_PASSWORD=replace-me
SMTP_FROM=noreply@staging.dxcon.test
SMTP_USE_TLS=true
STORAGE_PATH=/var/lib/dxcon/uploads
STORAGE_BACKEND=local
LOG_LEVEL=INFO
LOG_FORMAT=json
BUILD_VERSION=1.0.0-rc2-staging
GIT_SHA=local
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
STARTUP_VALIDATE_DB=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60
